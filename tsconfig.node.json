{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "playwright.config.ts", "api/**/*.ts", "scripts/**/*.ts", "src/types/**/*.ts", "src/domain/**/*.ts", "src/data/catalog-service.ts", "src/data/merge-catalog.ts"]
}
